{
  "name": "clinear",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsr generate && tsc && vite build",
    "check:types": "pnpm typecheck",
    "clockify:generate": "pnpm clockify:specs && pnpm clockify:generate:api && pnpm clockify:generate:reports",
    "clockify:generate:api": "node scripts/generate-clockify-client.mjs api",
    "clockify:generate:reports": "node scripts/generate-clockify-client.mjs reports",
    "clockify:spec": "curl -L https://docs.clockify.me/openapi.json -o src/services/clockify/specs/clockify-openapi.json",
    "clockify:specs": "pnpm clockify:spec && node scripts/prepare-clockify-specs.mjs",
    "dev": "vite",
    "format": "prettier --write . --ignore-unknown --cache --log-level=error && pnpm format:rust",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "lint": "eslint --fix --cache --format=pretty .",
    "preview": "vite preview",
    "release:check": "pnpm typecheck && pnpm build",
    "release:github": "scripts/publish-github-release.sh",
    "release:mac": "scripts/release-mac.sh",
    "setup": "pnpm install && pnpm run tauri:prebuild",
    "tauri": "tauri",
    "tauri:prebuild": "cargo build --manifest-path src-tauri/Cargo.toml --no-default-features",
    "typecheck": "tsr generate && tsc --noEmit"
  },
  "dependencies": {
    "@automattic/format-currency": "catalog:",
    "@fontsource-variable/intel-one-mono": "catalog:",
    "@fontsource-variable/oxanium": "catalog:",
    "@hookform/resolvers": "catalog:",
    "@linear/sdk": "catalog:",
    "@mantine/hooks": "catalog:",
    "@tabler/icons-react": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-table": "catalog:",
    "@tauri-apps/api": "catalog:",
    "@tauri-apps/plugin-log": "catalog:",
    "@tauri-apps/plugin-opener": "catalog:",
    "@tauri-apps/plugin-process": "catalog:",
    "@tauri-apps/plugin-store": "catalog:",
    "@tauri-apps/plugin-updater": "catalog:",
    "@zodios/core": "catalog:",
    "axios": "catalog:",
    "change-case": "catalog:",
    "clsx": "catalog:",
    "dayjs": "catalog:",
    "humanize-duration": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "react-timer-hook": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/router-cli": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "@types/humanize-duration": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "daisyui": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-formatter-pretty": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "globals": "catalog:",
    "openapi-zod-client": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-packagejson": "catalog:",
    "prettier-plugin-sh": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:"
  }
}
