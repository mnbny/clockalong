{
  "name": "clinear",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsr generate && tsc && vite build",
    "check:types": "pnpm typecheck",
    "dev": "vite",
    "format": "prettier --write . --ignore-unknown --cache --log-level=error && pnpm format:rust",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "lint": "eslint --fix --cache --format=pretty .",
    "preview": "vite preview",
    "setup": "pnpm install && pnpm run tauri:prebuild",
    "tauri": "tauri",
    "tauri:prebuild": "cargo build --manifest-path src-tauri/Cargo.toml --no-default-features",
    "typecheck": "tsr generate && tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/intel-one-mono": "5.2.2",
    "@fontsource-variable/oxanium": "5.2.8",
    "@mantine/hooks": "9.2.1",
    "@tabler/icons-react": "3.44.0",
    "@tanstack/react-query": "5.100.10",
    "@tanstack/react-router": "1.170.1",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-log": "2.8.0",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@tauri-apps/plugin-store": "2.4.3",
    "clsx": "2.1.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/router-cli": "1.167.2",
    "@tanstack/router-plugin": "1.168.2",
    "@tauri-apps/cli": "2.11.1",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "daisyui": "5.5.19",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-formatter-pretty": "7.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-sh": "0.18.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13"
  }
}
