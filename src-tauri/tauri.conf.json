{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clinear",
  "version": "0.1.0",
  "identifier": "app.moonbunny.clinear",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clinear",
        "theme": "Dark",
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false,
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        },
        "width": 1044,
        "height": 657,
        "minWidth": 1044,
        "minHeight": 657
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/mnbny/clinear/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZENjFFNDE1RTNGQjFBOTcKUldTWEd2dmpGZVJoYllUVnVkQll2KzJjUHl1aE54MzFnNnA2QWF5WnJMSTFZcWRKUkhYVURjQ1kK"
    }
  }
}
